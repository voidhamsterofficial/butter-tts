{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "butter-tts",
  "version": "0.7.0",
  "identifier": "com.samue.butter-tts",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Butter TTS",
        "width": 1040,
        "height": 800,
        "minWidth": 880,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
